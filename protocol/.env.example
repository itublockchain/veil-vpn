# VeilVPN Server Configuration
# Copy to .env and fill in values

# Core
BT_PAYMENT_SERVER=1
BT_HTTP_BIND=0.0.0.0:8080
BT_PUBLIC_IP=37.27.29.160
BT_WG_PORT=51820

# World ID (human-only nodes)
BT_WORLD_SIGNING_KEY=0x...
BT_WORLD_RP_ID=rp_...
BT_WORLD_ACTION=veil-vpn-connect
BT_HUMAN_ONLY=0

